{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Berlin",
  "minimumReleaseAge": "3 days",
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on the first day of the month"]
  },
  "packageRules": [
    {
      "description": "Group all non-major Python dependency updates into one PR",
      "matchManagers": ["uv"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "python-deps-non-major"
    },
    {
      "description": "Group all GitHub Actions updates into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Automerge dev/test/lint dependency patches",
      "matchManagers": ["uv"],
      "matchDepTypes": ["dependency-groups"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Major updates get individual PRs for review",
      "matchManagers": ["uv"],
      "matchUpdateTypes": ["major"],
      "groupName": null,
      "automerge": false
    }
  ]
}
